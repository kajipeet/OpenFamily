# ─────────────────────────────────────────────
# OpenFamily — environment variables
# Copy this file to .env and fill in real values
# ─────────────────────────────────────────────

# MongoDB credentials
MONGO_USER=admin
MONGO_PASSWORD=changeme_strong_password_here

# 64-char random string for JWT signing
JWT_SECRET=change_this_jwt_secret_to_64_random_chars_minimum_please_now

# EXACTLY 32 bytes (characters) for AES-256 encryption
ENCRYPTION_KEY=change_this_32byte_key_please!!!

# Initial admin account (created automatically on first run)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme_admin_please

# Ports exposed on the host
HTTP_PORT=80
HTTPS_PORT=443

# TURN server credentials (must match coturn/turnserver.conf)
TURN_SECRET=changeme_turn_secret

# Maximum accepted upload size in bytes (default: 10 GiB)
MAX_UPLOAD_BYTES=10737418240

# Chunk size in bytes for large uploads (default: 8 MiB)
UPLOAD_CHUNK_SIZE=8388608

# Domain/email for Let's Encrypt certbot renewal/export
CERTBOT_DOMAIN=
CERTBOT_EMAIL=
