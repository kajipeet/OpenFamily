lass=\"w-full border border-gray-200 rounded-xl px-3 py-2.5 text-sm outline-none focus:ring-2 focus:ring-green-300\"\n            placeholder=\"••••••••\"\n          />\n        </div>\n\n        <p v-if=\"error\" class=\"text-red-500 text-xs text-center\">{{ error }}</p>\n\n        <button\n          type=\"submit\"\n          :disabled=\"loading\"\n          class=\"w-full bg-green-700 hover:bg-green-800 text-white font-medium rounded-xl py-2.5 text-sm transition disabled:opacity-60\"\n        >\n          {{ loading ? 'Signing in…' : 'Sign In' }}\n        </button>\n      </form>\n\n      <p class=\"text-center text-xs text-gray-400 mt-6\">\n        <NuxtLink to=\"/\" class=\"hover:underline\">← Back to Home</NuxtLink>\n      </p>\n    </div>\n  </div>\n</template>\n\n<script setup lang=\"ts\">\ndefinePageMeta({ layout: false })\n\nuseSeoMeta({\n  title: 'Sign In - OpenFamily',\n  robots: 'noindex, nofollow',\n})\n\nconst { loginUser } = useAuth()\nconst router = useRouter()\n\nconst username = ref('')\nconst password = ref('')\nconst error = ref('')\nconst loading = ref(false)\n\nasync function login() {\n  error.value = ''\n  loading.value = true\n  try {\n    await loginUser(username.value, password.value)\n    await router.push('/app')\n  } catch (e: any) {\n    error.value = e.message || 'Invalid credentials'\n  } finally {\n    loading.value = false\n  }\n}\n</script>\n"],"version":3}